<?xml version="1.0" encoding="utf-8"?>
<project>

<!-- _________________________ Application Settings _________________________ -->

<!-- FIX: removed dashes from packageName — Android rejects them -->
<app title="FNF': Pico Engine" file="PicoEngine"
     packageName="com.PicoEngineTeam.lucas62944" package="The Funkin' Crew"
     main="lucas.states.funkin.scripts.backend.Main"
     version="2.26.5"
     company="Pico-Engine-Team + The Funkin' Crew" />

<!--Switch Export with Unique ApplicationID and Icon-->
<set name="APP_ID" value="0x0100f6c013bbc000" />

<!-- NOTE TO SELF: DISABLE THIS IF ISSUES ARE FOUND -->
<haxedef name="LINC_LUA_RELATIVE_DYNAMIC_LIB"/> <!-- stable luas -->

<!--The flixel preloader is not accurate in Chrome. You can use it regularly if you embed
    the swf into a html file or set the actual size of your file manually.-->
<!-- <app preloader="Preloader" resizable="true" /> -->
<app preloader="flixel.system.FlxPreloader" />

<!--Minimum without FLX_NO_GAMEPAD: 11.8, without FLX_NO_NATIVE_CURSOR: 11.2-->
<set name="SWF_VERSION" value="11.8" />

<!-- _____________________ PICO ENGINE / Psych ENGINE CUSTOMIZATION _____________________ -->

<define name="MODS_ALLOWED"      if="desktop" />
<define name="HSCRIPT_ALLOWED"   if="desktop" />
<define name="LUA_ALLOWED"       if="desktop" />
<define name="ACHIEVEMENTS_ALLOWED" />
<!-- FIX: Discord RPC does not compile on Android — restrict to desktop -->
<define name="DISCORD_ALLOWED"   if="desktop" />
<define name="TRANSLATIONS_ALLOWED" />
<define name="IRIS_DEBUG"/>
<define name="PICO_ALLOWED"/>
<define name="MULTITHREADED_LOADING" />
<define name="SHOW_LOADING_SCREEN" />
<define name="PSYCH_WATERMARKS"/>
<define name="CHECK_FOR_UPDATES" unless="web" />

<section if="officialBuild">
    <define name="TITLE_SCREEN_EASTER_EGG"/>
    <define name="BASE_GAME_FILES" />
    <define name="VIDEOS_ALLOWED" if="windows || linux || android || mac" unless="32bits"/>
</section>

<!-- _________________________ Window Settings _________________________ -->

<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" allow-high-dpi="true" />

<!--HTML5-specific-->
<window if="html5" resizable="true" />

<!--Desktop-specific-->
<window if="desktop" orientation="landscape" fullscreen="false" resizable="true" vsync="false"/>

<!--Mobile-specific-->
<window if="mobile" orientation="landscape" fullscreen="true" width="0" height="0" resizable="false"/>

<!--Switch-specific-->
<window if="switch" orientation="landscape" fullscreen="true" width="0" height="0" resizable="true" />

<!-- _________________________ Path Settings _________________________ -->

<set name="BUILD_DIR" value="export/debug"   if="debug" />
<set name="BUILD_DIR" value="export/release" unless="debug" />
<set name="BUILD_DIR" value="export/32bit"   if="32bits" />

<classpath name="source" />

<!-- _________________________ Android Permissions _________________________ -->

<section if="android">
    <dependency name="android.permission.INTERNET" />
    <dependency name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <dependency name="android.permission.READ_EXTERNAL_STORAGE" />
    <dependency name="android.permission.VIBRATE" />
    <!-- Required for storage access on Android 11+ -->
    <dependency name="android.permission.MANAGE_EXTERNAL_STORAGE" />
    <template path="templates/android" if="android" />
</section>

<!-- _________________________ Game Assets & Etc. _________________________ -->

<!-- Turn on Crash Handler -->
<define name="CRASH_HANDLER" if="desktop release" />

<!-- Assets -->
<assets path="assets/fonts" />
<assets path="assets/shared"      exclude="*.ogg" if="web"/>
<assets path="assets/shared"      exclude="*.mp3" unless="web"/>
<assets path="assets/embed"       exclude="*.ogg" if="web"  embed="true"/>
<assets path="assets/embed"       exclude="*.mp3" unless="web" embed="true"/>
<assets path="assets/videos"      if="VIDEOS_ALLOWED"/>
<assets path="assets/songs"       exclude="*.ogg" if="web"/>
<assets path="assets/songs"       exclude="*.mp3" unless="web"/>
<assets path="assets/week_assets" rename="assets" exclude="*.ogg" if="web"/>
<assets path="assets/week_assets" rename="assets" exclude="*.mp3" unless="web"/>

<section if="TITLE_SCREEN_EASTER_EGG">
    <assets path="assets/secrets" rename="assets/shared" exclude="*.ogg" if="web"/>
    <assets path="assets/secrets" rename="assets/shared" exclude="*.mp3" unless="web"/>
</section>

<section if="TRANSLATIONS_ALLOWED">
    <assets path="assets/translations" rename="assets" exclude="*.ogg" if="web"/>
    <assets path="assets/translations" rename="assets" exclude="*.mp3" unless="web"/>
</section>

<section if="BASE_GAME_FILES">
    <assets path="assets/base_game" rename="assets" exclude="*.ogg" if="web"/>
    <assets path="assets/base_game" rename="assets" exclude="*.mp3" unless="web"/>
    <haxelib name="grig.audio" if="BASE_GAME_FILES"/>
    <haxelib name="funkin.vis"  if="BASE_GAME_FILES"/>
</section>

<section if="MODS_ALLOWED">
    <assets path='example_mods' rename='content/mods' embed='false' type='template' unless="mac"/>
    <assets path='example_mods' rename='content/mods' embed='false' if="mac"/>
    <assets path='list.txt' rename='modsList.txt' />
</section>

<!-- OpenAL config (desktop only) -->
<section if="desktop">
    <assets path="alsoft.txt" rename="plugins/alsoft.ini"  type="text" if="windows"/>
    <assets path="alsoft.txt" rename="plugins/alsoft.conf" type="text" unless="windows"/>
    <assets path="alsoft.txt" rename="plugins/alsoft.dat"  type="text" if="windows"/>
    <assets path="content/audio-config.txt" rename="content/plugins/audio-config.ini"  type="text" if="windows"/>
    <assets path="content/audio-config.txt" rename="content/plugins/audio-config.conf" type="text" unless="windows"/>
    <assets path="content/updates/changelog.txt" rename="changelog.txt" type="text" unless="windows"/>
</section>

<!-- _________________________ Libraries _________________________ -->

<haxelib name="flixel"        version="5.6.1"/>
<haxelib name="flixel-addons" version="3.2.2"/>
<haxelib name="tjson"         version="1.4.0"/>

<!--Psych stuff needed-->
<haxelib name="linc_luajit"   if="LUA_ALLOWED"/>
<haxelib name="hscript-iris"  if="HSCRIPT_ALLOWED" version="1.1.3"/>
<haxelib name="hxvlc"         if="VIDEOS_ALLOWED" version="2.0.1"/>
<haxelib name="hxdiscord_rpc" version="1.2.4" if="DISCORD_ALLOWED"/>
<haxelib name="flxanimate"/>

<haxelib name="extension-androidtools" if="android" />

<!-- Disable Discord IO Thread -->
<haxedef name="DISCORD_DISABLE_IO_THREAD" if="hxdiscord_rpc" />

<haxedef name="NO_PRECOMPILED_HEADERS" if="linux" />

<!-- Enables a terminal log prompt on debug builds -->
<haxelib name="hxcpp-debug-server" if="debug"/>

<haxedef name="HXC_LIBVLC_LOGGING"      if="VIDEOS_ALLOWED debug" />
<haxedef name="HXVLC_NO_SHARE_DIRECTORY" if="VIDEOS_ALLOWED" />

<define name="x86_BUILD" if="32bits" />

<!-- _________________________ Haxedefines _________________________ -->

<!--Enable the Flixel core recording system-->
<!--<haxedef name="FLX_RECORD" />-->

<!--Disable the right and middle mouse buttons-->
<!-- <haxedef name="FLX_NO_MOUSE_ADVANCED" /> -->

<!--Disable the native cursor API on Flash-->
<!--<haxedef name="FLX_NO_NATIVE_CURSOR" />-->

<!--Optimise inputs for mobile — uncomment if not using mouse/keyboard-->
<!-- <haxedef name="FLX_NO_MOUSE"    if="mobile" /> -->
<!-- <haxedef name="FLX_NO_KEYBOARD" if="mobile" /> -->
<!-- <haxedef name="FLX_NO_TOUCH"    if="desktop" /> -->

<!--<haxedef name="FLX_NO_GAMEPAD" />-->

<!--Disable the Flixel core sound tray-->
<!--<haxedef name="FLX_NO_SOUND_TRAY" />-->

<!--Disable the Flixel sound management code-->
<!--<haxedef name="FLX_NO_SOUND_SYSTEM" />-->

<!--Disable the Flixel core focus lost screen-->
<haxedef name="FLX_NO_FOCUS_LOST_SCREEN" />

<!-- Show debug traces for hxCodec -->
<haxedef name="HXC_DEBUG_TRACE" if="debug" />

<!--Disable the Flixel core debugger. Automatically set in release mode.-->
<haxedef name="FLX_NO_DEBUG" unless="debug" />

<!--Enable this for Nape release builds for a serious performance improvement-->
<haxedef name="NAPE_RELEASE_BUILD" unless="debug" />

<!--Used for Izzy Engine's crash handler-->
<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER" />
<haxedef name="HXCPP_STACK_LINE"    if="CRASH_HANDLER" />
<haxedef name="HXCPP_STACK_TRACE"   if="CRASH_HANDLER" />

<!--Disable deprecated warnings-->
<haxedef name='no-deprecation-warnings' />

<!-- Haxe 4.3.0+: Enable pretty syntax errors and stuff. -->
<haxedef name="message.reporting" value="pretty" />

<!--Macro fixes-->
<haxeflag name="--macro" value="allowPackage('flash')" />
<haxeflag name="--macro" value="include('my.pack')" />

<haxedef name="hscriptPos" if="HSCRIPT_ALLOWED" />

<!-- ______________________________ Custom ______________________________ -->

<assets path='art/icons/iconOG.png' rename='icon.png' if="linux || mac" />
<icon path="art/icons/icon16.png" size='16'/>
<icon path="art/icons/icon32.png" size='32'/>
<icon path="art/icons/icon64.png" size='64'/>
<icon path="art/icons/iconOG.png" />

</project>
